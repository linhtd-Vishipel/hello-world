<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vessel_equipment_list" model="ir.ui.view">
        <field name="name">vessel.equipment.list</field>
        <field name="model">vessel.equipment</field>
        <field name="arch" type="xml">
            <list string="Equipment">
                <field name="vessel_id"/>
                <field name="equipment_type"/>
                <field name="serial_number"/>
                <field name="next_inspection_date"/>
                <field name="state" widget="badge" decoration-danger="state == 'faulty'"/>
            </list>
        </field>
    </record>

    <record id="view_vessel_equipment_form" model="ir.ui.view">
        <field name="name">vessel.equipment.form</field>
        <field name="model">vessel.equipment</field>
        <field name="arch" type="xml">
            <form string="Equipment">
                <sheet>
                    <group>
                        <field name="vessel_id"/>
                        <field name="equipment_type"/>
                        <field name="serial_number"/>
                        <field name="state"/>
                        <field name="install_date"/>
                        <field name="last_inspection_date"/>
                        <field name="next_inspection_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vessel_equipment_search" model="ir.ui.view">
        <field name="name">vessel.equipment.search</field>
        <field name="model">vessel.equipment</field>
        <field name="arch" type="xml">
            <search string="Equipment">
                <field name="vessel_id"/>
                <field name="serial_number"/>
                <filter string="Vessel" name="group_vessel" context="{'group_by': 'vessel_id'}"/>
                <filter string="Equipment Type" name="group_type" context="{'group_by': 'equipment_type'}"/>
            </search>
        </field>
    </record>

    <record id="action_vessel_equipment" model="ir.actions.act_window">
        <field name="name">Equipment</field>
        <field name="res_model">vessel.equipment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_vessel_equipment_search"/>
    </record>

</odoo>
