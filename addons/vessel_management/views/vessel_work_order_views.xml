<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vessel_work_order_list" model="ir.ui.view">
        <field name="name">vessel.work.order.list</field>
        <field name="model">vessel.work.order</field>
        <field name="arch" type="xml">
            <tree string="Work Orders">
                <field name="name"/>
                <field name="vessel_id"/>
                <field name="equipment_id"/>
                <field name="technician_id"/>
                <field name="date_open"/>
                <field name="state" widget="badge" decoration-success="state == 'done'" decoration-info="state == 'in_progress'"/>
            </tree>
        </field>
    </record>

    <record id="view_vessel_work_order_form" model="ir.ui.view">
        <field name="name">vessel.work.order.form</field>
        <field name="model">vessel.work.order</field>
        <field name="arch" type="xml">
            <form string="Work Order">
                <header>
                    <button name="action_start" string="Start" type="object" invisible="state != 'new'" class="oe_highlight"/>
                    <button name="action_done" string="Mark Done" type="object" invisible="state != 'in_progress'" class="oe_highlight"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="vessel_id"/>
                            <field name="equipment_id"/>
                        </group>
                        <group>
                            <field name="technician_id"/>
                            <field name="date_open"/>
                            <field name="date_closed" readonly="1"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_vessel_work_order_search" model="ir.ui.view">
        <field name="name">vessel.work.order.search</field>
        <field name="model">vessel.work.order</field>
        <field name="arch" type="xml">
            <search string="Work Orders">
                <field name="name"/>
                <field name="vessel_id"/>
                <field name="technician_id"/>
                <filter string="My Work Orders" name="my_work_orders" domain="[('technician_id', '=', uid)]"/>
                <filter string="Open" name="open" domain="[('state', 'in', ('new', 'in_progress'))]"/>
                <separator/>
                <filter string="Vessel" name="group_vessel" context="{'group_by': 'vessel_id'}"/>
                <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_vessel_work_order" model="ir.actions.act_window">
        <field name="name">Work Orders</field>
        <field name="res_model">vessel.work.order</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_vessel_work_order_search"/>
        <field name="context">{'search_default_open': 1}</field>
    </record>

</odoo>
